{
    "name": "sp-tarkov/forge",
    "type": "project",
    "description": "A Laravel-based web application that provides a platform for the Single Player Tarkov community to share and discover user-generated content, such as mods, guides, and other tools.",
    "keywords": [],
    "license": "MPL-2.0",
    "require": {
        "php": "^8.5",
        "ext-curl": "*",
        "ext-imagick": "*",
        "ext-intl": "*",
        "aws/aws-sdk-php": "^3.378.1",
        "composer/semver": "^3.4.4",
        "elgigi/commonmark-emoji": "^2.0",
        "geoip2/geoip2": "^3.3",
        "graham-campbell/markdown": "^16.1",
        "http-interop/http-factory-guzzle": "^1.2.1",
        "laravel/fortify": "^1.36.2",
        "laravel/framework": "^13.4",
        "laravel/horizon": "^5.45.5",
        "laravel/octane": "^2.17.1",
        "laravel/reverb": "^1.10.0",
        "laravel/sanctum": "^4.3.1",
        "laravel/scout": "^10.25",
        "laravel/serializable-closure": "^2.0.11",
        "laravel/socialite": "^5.26.1",
        "league/flysystem-aws-s3-v3": "^3.32",
        "league/html-to-markdown": "^5.1.1",
        "livewire/flux": "^2.13.2",
        "livewire/livewire": "^4.2.4",
        "mchev/banhammer": "^2.5.0",
        "meilisearch/meilisearch-php": "^1.16.1",
        "php-flasher/flasher-laravel": "^2.5.2",
        "shetabit/visitor": "^4.5.4",
        "socialiteproviders/discord": "^4.2",
        "spatie/laravel-discord-alerts": "^1.9.1",
        "spatie/laravel-flare": "^2.8.0",
        "spatie/laravel-honeypot": "^4.7.1",
        "sqids/sqids": "^0.5.0",
        "stevebauman/purify": "^6.3.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2.5",
        "driftingly/rector-laravel": "^2.3.0",
        "fakerphp/faker": "^1.24.1",
        "knuckleswtf/scribe": "^5.9",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.4.2",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.29.0",
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.3",
        "nunomaduro/essentials": "^1.2",
        "nunomaduro/pao": "^0.1.4",
        "pestphp/pest": "^4.4.5",
        "pestphp/pest-plugin-browser": "^4.3.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "rector/rector": "^2.4.1",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "rector": [
            "./vendor/bin/rector process --dry-run --config=rector.php"
        ],
        "rector-fix": [
            "./vendor/bin/rector process --config=rector.php"
        ],
        "coverage": [
            "./vendor/bin/pest --type-coverage --min=100"
        ],
        "phpstan": [
            "./vendor/bin/phpstan analyse --memory-limit=512M"
        ],
        "pint": [
            "./vendor/bin/pint --config pint.json"
        ],
        "spell": [
            "typos . --config ./typos.toml && echo 'DONE'"
        ],
        "lint": [
            "npm run lint"
        ],
        "lint:check": [
            "npm run test:lint"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "sendit": [
            "composer rector-fix",
            "composer lint",
            "composer pint",
            "composer phpstan",
            "composer spell",
            "composer coverage",
            "@php artisan test --parallel"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force",
            "@php artisan boost:update --ansi",
            "@php artisan clear",
            "@update:requirements"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --queue=long,default --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-pcntl": "8.0",
            "ext-posix": "8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
