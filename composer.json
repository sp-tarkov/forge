{
    "name": "sp-tarkov/forge",
    "type": "project",
    "description": "A Laravel-based web application that provides a platform for the Single Player Tarkov community to share and discover user-generated content, such as mods, guides, and other tools.",
    "keywords": [],
    "license": "MPL-2.0",
    "require": {
        "php": "^8.5",
        "ext-curl": "*",
        "ext-imagick": "*",
        "ext-intl": "*",
        "aws/aws-sdk-php": "^3.382.0",
        "composer/semver": "^3.4.4",
        "elgigi/commonmark-emoji": "^2.0",
        "geoip2/geoip2": "^3.3",
        "graham-campbell/markdown": "^16.1",
        "http-interop/http-factory-guzzle": "^1.2.1",
        "knuckleswtf/scribe": "^5.10",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.11.2",
        "laravel/horizon": "^5.47.0",
        "laravel/nightwatch": "^1.27.0",
        "laravel/octane": "^2.17.4",
        "laravel/reverb": "^1.10.2",
        "laravel/scout": "^10.25",
        "laravel/serializable-closure": "^2.0.13",
        "laravel/socialite": "^5.27.0",
        "league/flysystem-aws-s3-v3": "^3.34",
        "league/html-to-markdown": "^5.1.1",
        "livewire/flux": "^2.14.1",
        "livewire/flux-pro": "^2.14.1",
        "livewire/livewire": "^4.3.0",
        "mchev/banhammer": "^2.5.0",
        "meilisearch/meilisearch-php": "^1.16.1",
        "mobiledetect/mobiledetectlib": "~4.8.10",
        "nunomaduro/essentials": "^1.2",
        "shetabit/visitor": "^4.5.5",
        "socialiteproviders/discord": "^4.2",
        "spatie/laravel-discord-alerts": "^1.9.1",
        "spatie/laravel-honeypot": "^4.7.1",
        "sqids/sqids": "^0.5.0",
        "stevebauman/purify": "^6.3.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2.8",
        "calebdw/larastan-livewire": "^2.5",
        "driftingly/rector-laravel": "^2.4.0",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.6",
        "laravel/boost": "^2.4.8",
        "laravel/pail": "^1.2.6",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.29.1",
        "laravel/tinker": "^3.0.2",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.0",
        "pestphp/pest-plugin-browser": "^4.3.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "rector/rector": "^2.4.4",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "rector": [
            "./vendor/bin/rector process --config=rector.php"
        ],
        "rector:check": [
            "./vendor/bin/rector process --dry-run --config=rector.php"
        ],
        "coverage": [
            "./vendor/bin/pest --type-coverage --min=100"
        ],
        "phpstan": [
            "./vendor/bin/phpstan analyse --memory-limit=512M"
        ],
        "pint": [
            "./vendor/bin/pint --config pint.json"
        ],
        "pint:check": [
            "./vendor/bin/pint --config pint.json --test"
        ],
        "spell": [
            "typos . --config ./typos.toml && echo 'DONE'"
        ],
        "test": [
            "npm install playwright@latest",
            "npx playwright install",
            "./vendor/bin/pest --parallel --compact --testsuite=Feature,Unit",
            "./vendor/bin/pest --parallel --compact --testsuite=Browser"
        ],
        "format": [
            "@pint",
            "npm run lint"
        ],
        "format:check": [
            "@pint:check",
            "npm run test:lint"
        ],
        "lint": [
            "@rector",
            "@phpstan",
            "@coverage",
            "@spell"
        ],
        "lint:check": [
            "@rector:check",
            "@phpstan",
            "@coverage",
            "@spell"
        ],
        "sendit": [
            "Composer\\Config::disableProcessTimeout",
            "@format",
            "@lint",
            "@test"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan vendor:publish --tag=livewire:assets --ansi --force",
            "@php artisan boost:update --ansi",
            "@php artisan clear"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --queue=default,verification-detection,verification,long --tries=2 --timeout=900\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-pcntl": "8.0",
            "ext-posix": "8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "flux-pro",
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        }
    ]
}
